# Public site URL — used by sitemap, robots, llms.txt, canonical tags, and JSON-LD.
# Set in Vercel project settings (Production env). Never include trailing slash.
# Local dev fallback is set in src/lib/site.ts; preview deployments inherit Vercel-provided env.
NEXT_PUBLIC_SITE_URL=https://bndtrentals.com

# Phase 2+ (not yet wired):
# RESEND_API_KEY=
# RESEND_FROM=Burton NDT Rentals <quotes@bndtrentals.com>
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Sentry observability — already scaffolded in sentry.{client,server,edge}.config.ts
# and instrumentation.ts. Setting these flips it on at the next deploy.
# SENTRY_DSN=https://...@o....ingest.sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...
# SENTRY_AUTH_TOKEN=  # for source-map uploads in CI
#
# Portal integration (Phase 1+):
# CLIENT_ID=
# MASTER_API_URL=https://portal.makoai.studio
# MASTER_PUBLIC_KEY=
# TENANT_PRIVATE_KEY=
# TENANT_PUBLIC_KEY_KID=
